# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
out/
.turbo/
*.tsbuildinfo

# Env
.env
.env.local
.env*.local

